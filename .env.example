# CFO Agent — Environment Variables
# Rename this file to .env and fill in your values

# OpenAI API key (get from platform.openai.com)
OPENAI_API_KEY=sk-your-key-here

# Optional: email address to notify when reports are ready (uses Gmail via gws)
NOTIFY_EMAIL=you@yourcompany.com

# Optional: customize Google Drive folder names
# GWS_SOURCE_FOLDER=CFO-Agent/Drop-Files-Here
# GWS_REPORTS_FOLDER=CFO-Agent/Reports
# GWS_MEMOS_FOLDER=CFO-Agent/Board-Memos
# GWS_CASHFLOW_FOLDER=CFO-Agent/Cash-Flow
# GWS_VARIANCE_FOLDER=CFO-Agent/Budget-Variance

# Optional: change OpenAI model (gpt-4o-mini = cheapest, gpt-4o = more powerful)
# OPENAI_MODEL=gpt-4o-mini
